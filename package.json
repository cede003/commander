{
  "name": "commander",
  "author": "Christopher Ede",
  "version": "1.0.0",
  "description": "Electron desktop app with React, TypeScript, and Tailwind CSS",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\" \"npm:dev:public\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5174 && nodemon --config nodemon.json",
    "dev:public": "nodemon -q --watch public --ext json --exec \"rsync -a --delete public/ dist/public/\"",

    "clean": "rm -rf dist/ node_modules/.cache/ .vite/ logs/",
    "build": "npm run clean && npm run build:vite && npm run build:electron && npm run copy:engine && npm run copy:public",
    "build:vite": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "copy:engine": "mkdir -p dist/engine && rsync -av --delete engine/ dist/engine/",
    "copy:public": "mkdir -p dist/public && rsync -av --delete public/ dist/public/",

    "dist": "npm run build && electron-builder",
    "preview": "vite preview",
    "kill": "pkill -f 'electron' || true && pkill -f 'vite' || true && pkill -f 'node.*commander' || true && pkill -f 'python.*runner' || true && pkill -f 'nodemon' || true && echo 'All commander processes killed'"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "tailwind"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/which": "^3.0.4",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "nodemon": "^3.1.10",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "electron-context-menu": "^4.1.0",
    "langchain": "^0.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "winston": "^3.17.0"
  },
  "build": {
    "appId": "com.commander.app",
    "productName": "Commander",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    }
  }
}

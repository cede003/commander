{
  "metadata": {
    "name": "Conditional Form Automation",
    "author": "Workflow Builder",
    "description": "Demonstrates conditional execution based on form filling results",
    "version": "1.0.0"
  },
  "inputs": {
    "name": "Jane Smith",
    "email": "jane.smith@example.com",
    "should_fill_phone": true
  },
  "nodes": {
    "start_notification": {
      "type": "notification",
      "inputs": {
        "message": "Starting conditional form automation...",
        "level": "info"
      }
    },
    "fill_basic_form": {
      "type": "browser_autofill",
      "inputs": {
        "url": "https://httpbin.org/forms/post",
        "fields": {
          "input[name='custname']": "{{name}}",
          "input[name='custemail']": "{{email}}"
        }
      }
    },
    "fill_phone_conditionally": {
      "type": "browser_autofill",
      "inputs": {
        "url": "https://httpbin.org/forms/post",
        "fields": {
          "input[name='custtel']": "555-9876"
        }
      }
    },
    "success_notification": {
      "type": "notification",
      "inputs": {
        "message": "Form automation completed successfully!",
        "level": "success"
      }
    },
    "phone_filled_notification": {
      "type": "notification",
      "inputs": {
        "message": "Phone number was filled as requested",
        "level": "info"
      }
    }
  },
  "edges": [
    {
      "from": "start_notification",
      "to": "fill_basic_form"
    },
    {
      "from": "fill_basic_form",
      "to": "fill_phone_conditionally",
      "condition": "inputs['should_fill_phone'] == True"
    },
    {
      "from": "fill_phone_conditionally",
      "to": "phone_filled_notification"
    },
    {
      "from": "fill_basic_form",
      "to": "success_notification",
      "condition": "inputs['should_fill_phone'] == False"
    },
    {
      "from": "phone_filled_notification",
      "to": "success_notification"
    }
  ]
} 
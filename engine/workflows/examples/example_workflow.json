{
  "metadata": {
    "name": "Contact Form Automation",
    "author": "Workflow Builder",
    "description": "Automates filling out a contact form with notification",
    "version": "1.0.0"
  },
  "inputs": {
    "name": "John Doe",
    "email": "john.doe@example.com",
    "message": "Hello, this is a test message!"
  },
  "nodes": {
    "start_notification": {
      "type": "notification",
      "inputs": {
        "message": "Starting contact form automation...",
        "level": "info"
      }
    },
    "fill_contact_form": {
      "type": "browser_autofill",
      "inputs": {
        "url": "https://httpbin.org/forms/post",
        "fields": {
          "input[name='custname']": "{{name}}",
          "input[name='custtel']": "555-1234",
          "input[name='custemail']": "{{email}}",
          "textarea[name='comments']": "{{message}}"
        }
      }
    },
    "success_notification": {
      "type": "notification",
      "inputs": {
        "message": "Contact form filled successfully!",
        "level": "success"
      }
    }
  },
  "edges": [
    {
      "from": "start_notification",
      "to": "fill_contact_form"
    },
    {
      "from": "fill_contact_form",
      "to": "success_notification"
    }
  ]
} 
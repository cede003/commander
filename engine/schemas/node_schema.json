{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./node_schema.json",
  "title": "Structured Workflow Node Schema",
  "type": "object",
  "required": ["id", "domain", "operation"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the node."
    },
    "domain": {
      "type": "string",
      "description": "High-level domain for the node.",
      "enum": ["browser", "spreadsheet", "email", "file", "llm", "api"]
    },
    "operation": {
      "type": "string",
      "description": "Specific operation or action performed by this node (e.g., 'click', 'read_screen', 'extract_text')."
    },
    "inputs": {
      "type": "object",
      "description": "Runtime inputs such as selectors or text values. Shape depends on the operation.",
      "additionalProperties": true
    },
    "config": {
      "type": "object",
      "description": "Static configuration like timeouts, constants, and other parameters.",
      "additionalProperties": true
    },
    "outputs": {
      "type": "object",
      "description": "Optional schema describing outputs produced by the node.",
      "additionalProperties": true
    },
    "condition": {
      "type": "string",
      "description": "Optional expression to determine if this node should execute (e.g., JavaScript, JMESPath)."
    },
    "error_handling": {
      "$ref": "./error_handling_schema.json"
    },
    "async": {
      "type": "boolean",
      "description": "Whether the node runs asynchronously.",
      "default": false
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the node."
    }
  },
  "additionalProperties": false
}

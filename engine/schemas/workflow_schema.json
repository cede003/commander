{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workflow Schema",
  "type": "object",
  "required": ["metadata", "nodes", "edges"],
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Workflow metadata",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "description": "Name of the workflow" },
        "author": { "type": "string", "description": "Author of the workflow" },
        "description": { "type": "string", "description": "Description of the workflow" },
        "version": { "type": "string", "description": "Version of the workflow" }
      },
      "additionalProperties": false
    },
    "inputs": {
      "type": "object",
      "description": "Global inputs for the workflow",
      "additionalProperties": true
    },
    "nodes": {
      "type": "object",
      "description": "Nodes of the workflow, keyed by node id",
      "propertyNames": {
        "pattern": "^[a-zA-Z0-9_-]+$"
      },
      "additionalProperties": {
        "type": "object",
        "required": ["id", "domain", "type", "subtype"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the node"
          },
          "domain": {
            "type": "string",
            "description": "Domain/environment of the node",
            "enum": ["browser", "spreadsheet", "email", "file", "llm", "api"]
          },
          "type": {
            "type": "string",
            "description": "Type of node",
            "enum": ["action", "observation", "event", "notification", "wait_for_input"]
          },
          "subtype": {
            "type": "string",
            "description": "Subtype/specific operation of the node"
          },
          "status": {
            "type": "string",
            "description": "Current execution status of the node",
            "enum": ["queued", "running", "complete", "error", "skipped", "paused"],
            "default": "queued"
          },
          "status_message": {
            "type": "string",
            "description": "Additional status information or error message"
          },
          "started_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when node execution started"
          },
          "completed_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when node execution completed"
          },
          "execution_time": {
            "type": "number",
            "description": "Execution time in seconds"
          },
          "properties": {
            "type": "object",
            "description": "Static configuration properties for the node",
            "additionalProperties": true,
            "default": {}
          },
          "inputs": {
            "type": "object",
            "description": "Dynamic input data for this node",
            "additionalProperties": true,
            "default": {}
          },
          "outputs": {
            "type": "object",
            "description": "Outputs exposed by the node",
            "additionalProperties": true,
            "default": {}
          },
          "conditions": {
            "type": "string",
            "description": "Optional boolean expression to conditionally run this node"
          },
          "error_handling": {
            "type": "object",
            "description": "Node-specific error handling configuration",
            "properties": {
              "strategy": {
                "type": "string",
                "enum": ["retry", "fallback", "pause", "exit", "continue", "skip"],
                "description": "How to handle errors: retry the node, use fallback node, pause execution, exit workflow, continue to next node, or skip this node",
                "default": "continue"
              },
              "retry": { 
                "type": "boolean",
                "description": "Whether to retry on failure (deprecated, use strategy instead)"
              },
              "max_attempts": { 
                "type": "integer", 
                "minimum": 1,
                "description": "Maximum number of retry attempts",
                "default": 3
              },
              "retry_delay": {
                "type": "number",
                "minimum": 0,
                "description": "Delay in seconds between retry attempts",
                "default": 1
              },
              "fallback_node": { 
                "type": "string",
                "description": "ID of fallback node to execute if this node fails"
              },
              "pause_duration": {
                "type": "number",
                "minimum": 0,
                "description": "Duration in seconds to pause execution when error occurs",
                "default": 5
              },
              "error_message": {
                "type": "string",
                "description": "Custom error message to display when error occurs"
              },
              "log_level": {
                "type": "string",
                "enum": ["debug", "info", "warning", "error"],
                "description": "Log level for error messages",
                "default": "error"
              },
              "continue_on_error_types": {
                "type": "array",
                "items": { "type": "string" },
                "description": "List of error types to continue execution on (e.g., ['ValueError', 'TimeoutError'])"
              },
              "exit_on_error_types": {
                "type": "array",
                "items": { "type": "string" },
                "description": "List of error types to exit workflow on (e.g., ['KeyboardInterrupt', 'SystemExit'])"
              }
            },
            "additionalProperties": false
          },
          "async": {
            "type": "boolean",
            "description": "If true, node runs asynchronously"
          }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "description": "Directed edges between nodes",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": {
            "type": "string",
            "description": "ID of the source node"
          },
          "to": {
            "type": "string",
            "description": "ID of the target node"
          },
          "condition": {
            "type": "string",
            "description": "Optional condition expression to follow this edge"
          }
        },
        "additionalProperties": false
      }
    },
    "global_error_handling": {
      "type": "object",
      "description": "Global error handling configuration for the entire workflow",
      "properties": {
        "default_strategy": {
          "type": "string",
          "enum": ["retry", "fallback", "pause", "exit", "continue", "skip"],
          "description": "Default error handling strategy for nodes without specific error_handling",
          "default": "continue"
        },
        "max_retries": {
          "type": "integer",
          "minimum": 1,
          "description": "Default maximum retry attempts",
          "default": 3
        },
        "pause_on_error": {
          "type": "boolean",
          "description": "Whether to pause execution on any error",
          "default": false
        },
        "pause_duration": {
          "type": "number",
          "minimum": 0,
          "description": "Default pause duration in seconds",
          "default": 5
        },
        "exit_on_critical_errors": {
          "type": "boolean",
          "description": "Whether to exit workflow on critical errors",
          "default": true
        },
        "critical_error_types": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of error types considered critical",
          "default": ["KeyboardInterrupt", "SystemExit", "MemoryError"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

{
  "metadata": {
    "name": "Playwright Actions Demo",
    "description": "Demonstrates Playwright action functions: navigation, clicks, typing, form controls, drag-and-drop, hover/focus/blur, tap, selection, screenshot, scrolling",
    "workflow_version": "1.0.0",
    "schema_version": "1.0.0"
  },
  "inputs": {
    "base_url": "https://www.w3schools.com/howto/howto_css_custom_checkbox.asp",
    "example_url": "https://example.com"
  },
  "default_error_handling": {
    "strategy": "retry",
    "max_retry_attempts": 2,
    "retry_delay": 0.5
  },
  "nodes": {
    "notify_start": {
      "id": "notify_start",
      "domain": "browser",
      "type": "notification",
      "subtype": "console_log",
      "inputs": { "message": "Starting Playwright Actions Demo" }
    },
    "go_base": {
      "id": "go_base",
      "domain": "browser",
      "type": "action",
      "subtype": "goto",
      "inputs": { "url": "{{inputs.base_url}}" }
    },
    "wait_ready": {
      "id": "wait_ready",
      "domain": "browser",
      "type": "event",
      "subtype": "wait_for_timeout",
      "inputs": { "timeout": 500 }
    },
    "scroll_to_demo": {
      "id": "scroll_to_demo",
      "domain": "browser",
      "type": "action",
      "subtype": "scroll_to",
      "inputs": { "selector": "h2:has-text('Custom Checkbox')" }
    },
    "hover_header": {
      "id": "hover_header",
      "domain": "browser",
      "type": "action",
      "subtype": "hover",
      "inputs": { 
        "selector": "h1, h2",
        "timeout": 5000
      }
    },
    "focus_sample": {
      "id": "focus_sample",
      "domain": "browser",
      "type": "action",
      "subtype": "focus",
      "inputs": { "selector": "body" }
    },
    "blur_sample": {
      "id": "blur_sample",
      "domain": "browser",
      "type": "action",
      "subtype": "blur",
      "inputs": { "selector": "body" }
    },
    "check_box": {
      "id": "check_box",
      "domain": "browser",
      "type": "action",
      "subtype": "check",
      "inputs": { "selector": "input[type='checkbox']" }
    },
    "uncheck_box": {
      "id": "uncheck_box",
      "domain": "browser",
      "type": "action",
      "subtype": "uncheck",
      "inputs": { "selector": "input[type='checkbox']" }
    },
    "select_option_sample": {
      "id": "select_option_sample",
      "domain": "browser",
      "type": "action",
      "subtype": "select_option",
      "inputs": { "selector": "select", "value": "2" }
    },
    "fill_input": {
      "id": "fill_input",
      "domain": "browser",
      "type": "action",
      "subtype": "fill",
      "inputs": { "selector": "input[type='text'], input[type='search']", "value": "test input" }
    },
    "type_input": {
      "id": "type_input",
      "domain": "browser",
      "type": "action",
      "subtype": "type",
      "inputs": { "selector": "input[type='text'], input[type='search']", "text": " more" }
    },
    "press_enter": {
      "id": "press_enter",
      "domain": "browser",
      "type": "action",
      "subtype": "press",
      "inputs": { "key": "Enter" }
    },
    "goto_example": {
      "id": "goto_example",
      "domain": "browser",
      "type": "action",
      "subtype": "goto",
      "inputs": { "url": "{{inputs.example_url}}" }
    },
    "dblclick_h1": {
      "id": "dblclick_h1",
      "domain": "browser",
      "type": "action",
      "subtype": "dblclick",
      "inputs": { "selector": "h1" }
    },
    "tap_body": {
      "id": "tap_body",
      "domain": "browser",
      "type": "action",
      "subtype": "tap",
      "inputs": { "selector": "body" }
    },
    "drag_and_drop_demo": {
      "id": "drag_and_drop_demo",
      "domain": "browser",
      "type": "action",
      "subtype": "drag_and_drop",
      "inputs": { "source": "body", "target": "body" }
    },
    "screenshot_page": {
      "id": "screenshot_page",
      "domain": "browser",
      "type": "action",
      "subtype": "screenshot",
      "inputs": { "path": "logs/actions_demo_screenshot.png" }
    },
    "reload_page": {
      "id": "reload_page",
      "domain": "browser",
      "type": "action",
      "subtype": "reload",
      "inputs": {}
    },
    "go_back": {
      "id": "go_back",
      "domain": "browser",
      "type": "action",
      "subtype": "go_back",
      "inputs": {}
    },
    "go_forward": {
      "id": "go_forward",
      "domain": "browser",
      "type": "action",
      "subtype": "go_forward",
      "inputs": {}
    },
    "click_body": {
      "id": "click_body",
      "domain": "browser",
      "type": "action",
      "subtype": "click",
      "inputs": { "selector": "body" }
    },
    "notify_end": {
      "id": "notify_end",
      "domain": "browser",
      "type": "notification",
      "subtype": "console_log",
      "inputs": { "message": "Finished Playwright Actions Demo" }
    }
  },
  "edges": [
    { "from": "notify_start", "to": "go_base" },
    { "from": "go_base", "to": "wait_ready" },
    { "from": "wait_ready", "to": "scroll_to_demo" },
    { "from": "scroll_to_demo", "to": "hover_header" },
    { "from": "hover_header", "to": "focus_sample" },
    { "from": "focus_sample", "to": "blur_sample" },
    { "from": "blur_sample", "to": "check_box" },
    { "from": "check_box", "to": "uncheck_box" },
    { "from": "uncheck_box", "to": "select_option_sample" },
    { "from": "select_option_sample", "to": "fill_input" },
    { "from": "fill_input", "to": "type_input" },
    { "from": "type_input", "to": "press_enter" },
    { "from": "press_enter", "to": "goto_example" },
    { "from": "goto_example", "to": "dblclick_h1" },
    { "from": "dblclick_h1", "to": "tap_body" },
    { "from": "tap_body", "to": "drag_and_drop_demo" },
    { "from": "drag_and_drop_demo", "to": "screenshot_page" },
    { "from": "screenshot_page", "to": "reload_page" },
    { "from": "reload_page", "to": "go_back" },
    { "from": "go_back", "to": "go_forward" },
    { "from": "go_forward", "to": "click_body" },
    { "from": "click_body", "to": "notify_end" }
  ]
}


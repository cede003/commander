{
  "metadata": {
    "name": "Playwright Actions Demo",
    "description": "Demonstrates Playwright action functions: navigation, clicks, typing, form controls, drag-and-drop, hover/focus/blur, tap, selection, screenshot, scrolling",
    "workflow_version": "1.0.0",
    "schema_version": "1.0.0"
  },
  "properties": {
    "base_url": "https://www.w3schools.com/howto/howto_css_custom_checkbox.asp",
    "example_url": "https://example.com"
  },
  "default_error_handling": {
    "strategy": "retry",
    "max_retry_attempts": 2,
    "retry_delay": 0.5
  },
  "nodes": {
    "notify_start": {
      "id": "notify_start",
      "domain": "browser",
      "properties": {
        "message": "Starting Playwright Actions Demo"
      },
      "operation": "console_log"
    },
    "go_base": {
      "id": "go_base",
      "domain": "browser",
      "properties": {
        "url": "{{inputs.base_url}}"
      },
      "operation": "goto"
    },
    "wait_ready": {
      "id": "wait_ready",
      "domain": "browser",
      "properties": {
        "timeout": 500
      },
      "operation": "wait_for_timeout"
    },
    "scroll_to_demo": {
      "id": "scroll_to_demo",
      "domain": "browser",
      "properties": {
        "selector": "h2:has-text('Custom Checkbox')"
      },
      "operation": "scroll_to"
    },
    "hover_header": {
      "id": "hover_header",
      "domain": "browser",
      "properties": {
        "selector": "h1, h2",
        "timeout": 5000
      },
      "operation": "hover"
    },
    "focus_sample": {
      "id": "focus_sample",
      "domain": "browser",
      "properties": {
        "selector": "body"
      },
      "operation": "focus"
    },
    "blur_sample": {
      "id": "blur_sample",
      "domain": "browser",
      "properties": {
        "selector": "body"
      },
      "operation": "blur"
    },
    "check_box": {
      "id": "check_box",
      "domain": "browser",
      "properties": {
        "selector": "input[type='checkbox']"
      },
      "operation": "check"
    },
    "uncheck_box": {
      "id": "uncheck_box",
      "domain": "browser",
      "properties": {
        "selector": "input[type='checkbox']"
      },
      "operation": "uncheck"
    },
    "select_option_sample": {
      "id": "select_option_sample",
      "domain": "browser",
      "properties": {
        "selector": "select",
        "value": "2"
      },
      "operation": "select_option"
    },
    "fill_input": {
      "id": "fill_input",
      "domain": "browser",
      "properties": {
        "selector": "input[type='text'], input[type='search']",
        "value": "test input"
      },
      "operation": "fill"
    },
    "type_input": {
      "id": "type_input",
      "domain": "browser",
      "properties": {
        "selector": "input[type='text'], input[type='search']",
        "text": " more"
      },
      "operation": "type"
    },
    "press_enter": {
      "id": "press_enter",
      "domain": "browser",
      "properties": {
        "key": "Enter"
      },
      "operation": "press"
    },
    "goto_example": {
      "id": "goto_example",
      "domain": "browser",
      "properties": {
        "url": "{{inputs.example_url}}"
      },
      "operation": "goto"
    },
    "dblclick_h1": {
      "id": "dblclick_h1",
      "domain": "browser",
      "properties": {
        "selector": "h1"
      },
      "operation": "dblclick"
    },
    "tap_body": {
      "id": "tap_body",
      "domain": "browser",
      "properties": {
        "selector": "body"
      },
      "operation": "tap"
    },
    "drag_and_drop_demo": {
      "id": "drag_and_drop_demo",
      "domain": "browser",
      "properties": {
        "source": "body",
        "target": "body"
      },
      "operation": "drag_to"
    },
    "screenshot_page": {
      "id": "screenshot_page",
      "domain": "browser",
      "properties": {
        "path": "logs/actions_demo_screenshot.png"
      },
      "operation": "screenshot"
    },
    "reload_page": {
      "id": "reload_page",
      "domain": "browser",
      "properties": {},
      "operation": "reload"
    },
    "go_back": {
      "id": "go_back",
      "domain": "browser",
      "properties": {},
      "operation": "go_back"
    },
    "go_forward": {
      "id": "go_forward",
      "domain": "browser",
      "properties": {},
      "operation": "go_forward"
    },
    "click_body": {
      "id": "click_body",
      "domain": "browser",
      "properties": {
        "selector": "body"
      },
      "operation": "click"
    },
    "notify_end": {
      "id": "notify_end",
      "domain": "browser",
      "properties": {
        "message": "Finished Playwright Actions Demo"
      },
      "operation": "console_log"
    }
  },
  "edges": [
    {
      "from": "notify_start",
      "to": "go_base"
    },
    {
      "from": "go_base",
      "to": "wait_ready"
    },
    {
      "from": "wait_ready",
      "to": "scroll_to_demo"
    },
    {
      "from": "scroll_to_demo",
      "to": "hover_header"
    },
    {
      "from": "hover_header",
      "to": "focus_sample"
    },
    {
      "from": "focus_sample",
      "to": "blur_sample"
    },
    {
      "from": "blur_sample",
      "to": "check_box"
    },
    {
      "from": "check_box",
      "to": "uncheck_box"
    },
    {
      "from": "uncheck_box",
      "to": "select_option_sample"
    },
    {
      "from": "select_option_sample",
      "to": "fill_input"
    },
    {
      "from": "fill_input",
      "to": "type_input"
    },
    {
      "from": "type_input",
      "to": "press_enter"
    },
    {
      "from": "press_enter",
      "to": "goto_example"
    },
    {
      "from": "goto_example",
      "to": "dblclick_h1"
    },
    {
      "from": "dblclick_h1",
      "to": "tap_body"
    },
    {
      "from": "tap_body",
      "to": "drag_and_drop_demo"
    },
    {
      "from": "drag_and_drop_demo",
      "to": "screenshot_page"
    },
    {
      "from": "screenshot_page",
      "to": "reload_page"
    },
    {
      "from": "reload_page",
      "to": "go_back"
    },
    {
      "from": "go_back",
      "to": "go_forward"
    },
    {
      "from": "go_forward",
      "to": "click_body"
    },
    {
      "from": "click_body",
      "to": "notify_end"
    }
  ]
}
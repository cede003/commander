{
  "metadata": {
    "name": "Playwright Observations Demo",
    "description": "Demonstrates Playwright observation functions: title/url, visibility, attributes, HTML, bounding boxes, query selector(s)",
    "workflow_version": "1.0.0",
    "schema_version": "1.0.0"
  },
  "arguments": {
    "url": "https://example.com",
    "form_url": "https://www.w3schools.com/howto/howto_css_custom_checkbox.asp"
  },
  "default_error_handling": {
    "strategy": "retry",
    "max_attempts": 2,
    "retry_delay": 0.5
  },
  "nodes": {
    "start_log": {
      "id": "start_log",
      "domain": "browser",
      "arguments": {
        "message": "Starting Playwright Observations Demo"
      },
      "operation": "console_log"
    },
    "goto_form": {
      "id": "goto_form",
      "domain": "browser",
      "arguments": {
        "url": "{{inputs.form_url}}"
      },
      "operation": "goto"
    },
    "wait_form": {
      "id": "wait_form",
      "domain": "browser",
      "arguments": {
        "timeout": 500
      },
      "operation": "wait_for_timeout"
    },
    "text_content_h1": {
      "id": "text_content_h1",
      "domain": "browser",
      "arguments": {
        "selector": "h1, h2"
      },
      "operation": "text_content"
    },
    "is_checkbox_enabled": {
      "id": "is_checkbox_enabled",
      "domain": "browser",
      "arguments": {
        "selector": "input[type='checkbox']"
      },
      "operation": "is_enabled"
    },
    "is_checkbox_disabled": {
      "id": "is_checkbox_disabled",
      "domain": "browser",
      "arguments": {
        "selector": "input[type='checkbox']"
      },
      "operation": "is_disabled"
    },
    "is_checkbox_checked": {
      "id": "is_checkbox_checked",
      "domain": "browser",
      "arguments": {
        "selector": "input[type='checkbox']"
      },
      "operation": "is_checked"
    },
    "goto": {
      "id": "goto",
      "domain": "browser",
      "arguments": {
        "url": "{{inputs.url}}"
      },
      "operation": "goto"
    },
    "wait": {
      "id": "wait",
      "domain": "browser",
      "arguments": {
        "timeout": 500
      },
      "operation": "wait_for_timeout"
    },
    "get_title": {
      "id": "get_title",
      "domain": "browser",
      "arguments": {},
      "operation": "title"
    },
    "get_title_alias": {
      "id": "get_title_alias",
      "domain": "browser",
      "arguments": {},
      "operation": "get_title"
    },
    "get_url": {
      "id": "get_url",
      "domain": "browser",
      "arguments": {},
      "operation": "url"
    },
    "is_h1_visible": {
      "id": "is_h1_visible",
      "domain": "browser",
      "arguments": {
        "selector": "h1"
      },
      "operation": "is_visible"
    },
    "is_h1_hidden": {
      "id": "is_h1_hidden",
      "domain": "browser",
      "arguments": {
        "selector": "h1.nonexistent"
      },
      "operation": "is_hidden"
    },
    "query_selector_h1": {
      "id": "query_selector_h1",
      "domain": "browser",
      "arguments": {
        "selector": "h1"
      },
      "operation": "query_selector"
    },
    "query_selector_all_p": {
      "id": "query_selector_all_p",
      "domain": "browser",
      "arguments": {
        "selector": "p"
      },
      "operation": "query_selector_all"
    },
    "get_attr_lang": {
      "id": "get_attr_lang",
      "domain": "browser",
      "arguments": {
        "selector": "html",
        "attribute": "lang"
      },
      "operation": "get_attribute"
    },
    "content": {
      "id": "content",
      "domain": "browser",
      "arguments": {},
      "operation": "content"
    },
    "inner_html_h1": {
      "id": "inner_html_h1",
      "domain": "browser",
      "arguments": {
        "selector": "h1"
      },
      "operation": "inner_html"
    },
    "outer_html_h1": {
      "id": "outer_html_h1",
      "domain": "browser",
      "arguments": {
        "selector": "h1"
      },
      "operation": "outer_html"
    },
    "bbox_h1": {
      "id": "bbox_h1",
      "domain": "browser",
      "arguments": {
        "selector": "h1"
      },
      "operation": "bounding_box"
    },
    "end_log": {
      "id": "end_log",
      "domain": "browser",
      "arguments": {
        "message": "Finished Playwright Observations Demo. Title={{results.get_title.result}} URL={{results.get_url.result}}"
      },
      "operation": "console_log"
    }
  },
  "edges": [
    {
      "from": "start_log",
      "to": "goto"
    },
    {
      "from": "goto",
      "to": "wait"
    },
    {
      "from": "wait",
      "to": "get_title"
    },
    {
      "from": "get_title",
      "to": "get_title_alias"
    },
    {
      "from": "get_title_alias",
      "to": "get_url"
    },
    {
      "from": "get_url",
      "to": "is_h1_visible"
    },
    {
      "from": "is_h1_visible",
      "to": "is_h1_hidden"
    },
    {
      "from": "is_h1_hidden",
      "to": "query_selector_h1"
    },
    {
      "from": "query_selector_h1",
      "to": "query_selector_all_p"
    },
    {
      "from": "query_selector_all_p",
      "to": "get_attr_lang"
    },
    {
      "from": "get_attr_lang",
      "to": "content"
    },
    {
      "from": "content",
      "to": "inner_html_h1"
    },
    {
      "from": "inner_html_h1",
      "to": "outer_html_h1"
    },
    {
      "from": "outer_html_h1",
      "to": "bbox_h1"
    },
    {
      "from": "bbox_h1",
      "to": "goto_form"
    },
    {
      "from": "goto_form",
      "to": "wait_form"
    },
    {
      "from": "wait_form",
      "to": "text_content_h1"
    },
    {
      "from": "text_content_h1",
      "to": "is_checkbox_enabled"
    },
    {
      "from": "is_checkbox_enabled",
      "to": "is_checkbox_disabled"
    },
    {
      "from": "is_checkbox_disabled",
      "to": "is_checkbox_checked"
    },
    {
      "from": "is_checkbox_checked",
      "to": "end_log"
    }
  ]
}
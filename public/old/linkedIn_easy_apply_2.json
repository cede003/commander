{
  "metadata": {
    "name": "LinkedIn Easy Apply 2",
    "author": "cede",
    "description": "Clicks Next repeatedly until it no longer exists",
    "version": "1.0.0"
  },
  "arguments": {},
  "nodes": {
    "kickoff_click": {
      "id": "kickoff_click",
      "domain": "browser",
      "arguments": {
        "selector": "#jobs-apply-button-id",
        "timeout": 3000
      },
      "error_handling": {
        "strategy": "skip",
        "error_message": "Initial Next not found; skipping to loop"
      },
      "operation": "click"
    },
    "loop_click": {
      "id": "loop_click",
      "domain": "browser",
      "arguments": {
        "selector": "button[data-easy-apply-next-button]",
        "timeout": 1500
      },
      "error_handling": {
        "strategy": "exit",
        "error_message": "No more Next buttons; finishing workflow"
      },
      "operation": "click"
    }
  },
  "edges": [
    {
      "from": "kickoff_click",
      "to": "loop_click"
    },
    {
      "from": "loop_click",
      "to": "loop_click"
    }
  ]
}
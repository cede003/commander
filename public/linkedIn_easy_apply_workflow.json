{
  "metadata": {
    "name": "LinkedIn Easy Apply Workflow",
    "author": "cede",
    "description": "Clicks Easy Apply and checks form field completeness",
    "version": "1.0.0"
  },
  "properties": {},
  "nodes": {
    "click_easy_apply": {
      "id": "click_easy_apply",
      "domain": "browser",
      "properties": {
        "selector": "#jobs-apply-button-id",
        "timeout": 5000
      },
      "operation": "click"
    },
    "log_click_result": {
      "id": "log_click_result",
      "domain": "browser",
      "properties": {
        "message": "Click successful: {{results.click_easy_apply.success}}",
        "level": "success"
      },
      "operation": "console_log"
    },
    "log_node_status": {
      "id": "log_node_status",
      "domain": "browser",
      "properties": {
        "message": "Node status will be available after execution",
        "level": "info"
      },
      "operation": "console_log"
    }
  },
  "edges": [
    {
      "from": "click_easy_apply",
      "to": "log_click_result"
    },
    {
      "from": "log_click_result",
      "to": "log_node_status"
    }
  ]
}
{
    "metadata": {
      "name": "LinkedIn Easy Apply Workflow",
      "author": "cede",
      "description": "Clicks Easy Apply and checks form field completeness",
      "version": "1.0.0"
    },
    "inputs": {},
    "nodes": {
      "click_easy_apply": {
        "id": "click_easy_apply",
        "domain": "browser",
        "type": "action",
        "subtype": "click",
        "inputs": {
          "selector": "#jobs-apply-button-id",
          "timeout": 5000
        },
        "outputs": {
          "clicked": true
        }
      },
      "log_easy_apply_clicked": {
        "id": "log_easy_apply_clicked",
        "domain": "browser",
        "type": "notification",
        "subtype": "console_log",
        "inputs": {
            "message": "{{results.click_easy_apply.result}}",
            "level": "success"
        }
      }
    },
    "edges": [
      {
        "from": "click_easy_apply",
        "to": "log_easy_apply_clicked"
      }
    ]   
}
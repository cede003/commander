{
  "metadata": {
    "name": "Status Demo Workflow",
    "author": "cede",
    "description": "Demonstrates node status tracking with different scenarios",
    "version": "1.0.0"
  },
  "properties": {},
  "nodes": {
    "success_node": {
      "id": "success_node",
      "domain": "browser",
      "status": "queued",
      "properties": {
        "message": "This node will complete successfully",
        "level": "success"
      },
      "operation": "console_log"
    },
    "error_node": {
      "id": "error_node",
      "domain": "browser",
      "status": "queued",
      "properties": {
        "selector": "#non-existent-element",
        "timeout": 1000
      },
      "error_handling": {
        "strategy": "continue",
        "error_message": "Element not found - continuing anyway"
      },
      "operation": "click"
    },
    "skip_node": {
      "id": "skip_node",
      "domain": "browser",
      "status": "queued",
      "properties": {
        "selector": "#another-non-existent-element",
        "timeout": 1000
      },
      "error_handling": {
        "strategy": "skip",
        "error_message": "Skipping this node"
      },
      "operation": "click"
    },
    "final_node": {
      "id": "final_node",
      "domain": "browser",
      "status": "queued",
      "properties": {
        "message": "Workflow completed - check node statuses!",
        "level": "info"
      },
      "operation": "console_log"
    }
  },
  "edges": [
    {
      "from": "success_node",
      "to": "error_node"
    },
    {
      "from": "error_node",
      "to": "skip_node"
    },
    {
      "from": "skip_node",
      "to": "final_node"
    }
  ]
}
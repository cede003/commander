{
  "metadata": {
    "name": "Minimal Workflow Test",
    "description": "Test workflow using minimal boilerplate functions",
    "author": "System",
    "version": "1.0.0"
  },
  "inputs": {
    "search_url": "https://www.google.com",
    "search_term": "playwright automation"
  },
  "nodes": {
    "navigate": {
      "id": "navigate",
      "domain": "browser",
      "type": "action",
      "subtype": "goto",
      "inputs": {
        "url": "{{inputs.search_url}}"
      }
    },
    "wait_for_page": {
      "id": "wait_for_page",
      "domain": "browser",
      "type": "event",
      "subtype": "wait_for_load_state",
      "inputs": {
        "state": "load"
      }
    },
    "fill_search": {
      "id": "fill_search",
      "domain": "browser",
      "type": "action",
      "subtype": "fill",
      "inputs": {
        "selector": "textarea[name='q'], input[name='q']",
        "value": "{{inputs.search_term}}"
      }
    },
    "click_search": {
      "id": "click_search",
      "domain": "browser",
      "type": "action",
      "subtype": "click",
      "inputs": {
        "selector": "input[name='btnK'], button[name='btnK']"
      }
    },
    "get_title": {
      "id": "get_title",
      "domain": "browser",
      "type": "observation",
      "subtype": "get_title",
      "inputs": {}
    },
    "log_result": {
      "id": "log_result",
      "domain": "browser",
      "type": "notification",
      "subtype": "console_log",
      "inputs": {
        "message": "Workflow completed successfully!",
        "level": "success"
      }
    }
  },
  "edges": [
    {
      "from": "navigate",
      "to": "wait_for_page"
    },
    {
      "from": "wait_for_page",
      "to": "fill_search"
    },
    {
      "from": "fill_search",
      "to": "click_search"
    },
    {
      "from": "click_search",
      "to": "get_title"
    },
    {
      "from": "get_title",
      "to": "log_result"
    }
  ]
} 
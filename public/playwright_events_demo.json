{
  "metadata": {
    "name": "Playwright Events Demo",
    "description": "Demonstrates Playwright wait and event functions: wait_for_selector, wait_for_load_state, wait_for_function, wait_for_event, expect_response, expect_request, wait_for_url, wait_for_timeout, expect_download, expect_file_chooser, expect_popup",
    "workflow_version": "1.0.0",
    "schema_version": "1.0.0"
  },
  "properties": {
    "url": "https://example.com",
    "network_url": "https://www.wikipedia.org"
  },
  "default_error_handling": {
    "strategy": "retry",
    "max_attempts": 2,
    "retry_delay": 0.5
  },
  "nodes": {
    "start_log": {
      "id": "start_log",
      "domain": "browser",
      "properties": {
        "message": "Starting Playwright Events Demo"
      },
      "operation": "console_log"
    },
    "goto_network": {
      "id": "goto_network",
      "domain": "browser",
      "properties": {
        "url": "{{inputs.network_url}}"
      },
      "operation": "goto"
    },
    "wait_request": {
      "id": "wait_request",
      "domain": "browser",
      "properties": {
        "url_or_predicate": "**wikipedia**"
      },
      "operation": "expect_request"
    },
    "wait_response": {
      "id": "wait_response",
      "domain": "browser",
      "properties": {
        "url_or_predicate": "**wikipedia**"
      },
      "operation": "expect_response"
    },
    "wait_console_event": {
      "id": "wait_console_event",
      "domain": "browser",
      "properties": {
        "event": "console"
      },
      "operation": "wait_for_event"
    },
    "goto": {
      "id": "goto",
      "domain": "browser",
      "properties": {
        "url": "{{inputs.url}}"
      },
      "operation": "goto"
    },
    "wait_load_dom": {
      "id": "wait_load_dom",
      "domain": "browser",
      "properties": {
        "state": "domcontentloaded"
      },
      "operation": "wait_for_load_state"
    },
    "wait_h1": {
      "id": "wait_h1",
      "domain": "browser",
      "properties": {
        "selector": "h1"
      },
      "operation": "wait_for_selector"
    },
    "wait_fn": {
      "id": "wait_fn",
      "domain": "browser",
      "properties": {
        "function": "() => document.title.length > 0"
      },
      "operation": "wait_for_function"
    },
    "wait_url": {
      "id": "wait_url",
      "domain": "browser",
      "properties": {
        "url": "**example**"
      },
      "operation": "wait_for_url"
    },
    "wait_timeout": {
      "id": "wait_timeout",
      "domain": "browser",
      "properties": {
        "timeout": 250
      },
      "operation": "wait_for_timeout"
    },
    "try_wait_download": {
      "id": "try_wait_download",
      "domain": "browser",
      "properties": {},
      "operation": "expect_download"
    },
    "try_wait_file_chooser": {
      "id": "try_wait_file_chooser",
      "domain": "browser",
      "properties": {},
      "operation": "expect_file_chooser"
    },
    "try_wait_popup": {
      "id": "try_wait_popup",
      "domain": "browser",
      "properties": {},
      "operation": "expect_popup"
    },
    "end_log": {
      "id": "end_log",
      "domain": "browser",
      "properties": {
        "message": "Finished Playwright Events Demo"
      },
      "operation": "console_log"
    }
  },
  "edges": [
    {
      "from": "start_log",
      "to": "goto"
    },
    {
      "from": "goto",
      "to": "wait_load_dom"
    },
    {
      "from": "wait_load_dom",
      "to": "wait_h1"
    },
    {
      "from": "wait_h1",
      "to": "wait_fn"
    },
    {
      "from": "wait_fn",
      "to": "wait_url"
    },
    {
      "from": "wait_url",
      "to": "wait_timeout"
    },
    {
      "from": "wait_timeout",
      "to": "goto_network"
    },
    {
      "from": "goto_network",
      "to": "wait_request"
    },
    {
      "from": "wait_request",
      "to": "wait_response"
    },
    {
      "from": "wait_response",
      "to": "wait_console_event"
    },
    {
      "from": "wait_console_event",
      "to": "try_wait_download"
    },
    {
      "from": "try_wait_download",
      "to": "try_wait_file_chooser"
    },
    {
      "from": "try_wait_file_chooser",
      "to": "try_wait_popup"
    },
    {
      "from": "try_wait_popup",
      "to": "end_log"
    }
  ]
}
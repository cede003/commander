{
  "metadata": {
    "name": "News Headlines Workflow",
    "description": "Navigate to a news website and extract the latest headlines",
    "author": "Commander",
    "version": "1.0.0"
  },
  "inputs": {
    "news_url": "https://www.bbc.com/news",
    "max_headlines": 5
  },
  "nodes": {
    "start_notification": {
      "id": "start_notification",
      "domain": "browser",
      "type": "notification",
      "subtype": "console_log",
      "inputs": {
        "message": "Starting news headlines workflow",
        "level": "info"
      }
    },
    "navigate_to_news": {
      "id": "navigate_to_news",
      "domain": "browser",
      "type": "action",
      "subtype": "goto",
      "inputs": {
        "url": "{{inputs.news_url}}"
      },
      "error_handling": {
        "retry": true,
        "max_attempts": 3
      }
    },
    "wait_for_page_load": {
      "id": "wait_for_page_load",
      "domain": "browser",
      "type": "event",
      "subtype": "wait_for_timeout",
      "inputs": {
        "timeout": 3000
      }
    },
    "scroll_to_load_more": {
      "id": "scroll_to_load_more",
      "domain": "browser",
      "type": "action",
      "subtype": "press",
      "inputs": {
        "key": "PageDown"
      }
    },
    "wait_for_scroll": {
      "id": "wait_for_scroll",
      "domain": "browser",
      "type": "event",
      "subtype": "wait_for_timeout",
      "inputs": {
        "timeout": 2000
      }
    },
    "get_headlines": {
      "id": "get_headlines",
      "domain": "browser",
      "type": "observation",
      "subtype": "query_selector_all",
      "inputs": {
        "selector": "h1, h2, h3, .headline, .title, [class*='headline'], [class*='title']"
      }
    },
    "get_page_title": {
      "id": "get_page_title",
      "domain": "browser",
      "type": "observation",
      "subtype": "get_title",
      "inputs": {}
    },
    "get_current_url": {
      "id": "get_current_url",
      "domain": "browser",
      "type": "observation",
      "subtype": "url",
      "inputs": {}
    },
    "log_headlines": {
      "id": "log_headlines",
      "domain": "browser",
      "type": "notification",
      "subtype": "console_log",
      "inputs": {
        "message": "Successfully extracted news headlines",
        "level": "success"
      }
    }
  },
  "edges": [
    {
      "from": "start_notification",
      "to": "navigate_to_news"
    },
    {
      "from": "navigate_to_news",
      "to": "wait_for_page_load"
    },
    {
      "from": "wait_for_page_load",
      "to": "scroll_to_load_more"
    },
    {
      "from": "scroll_to_load_more",
      "to": "wait_for_scroll"
    },
    {
      "from": "wait_for_scroll",
      "to": "get_headlines"
    },
    {
      "from": "get_headlines",
      "to": "get_page_title"
    },
    {
      "from": "get_page_title",
      "to": "get_current_url"
    },
    {
      "from": "get_current_url",
      "to": "log_headlines"
    }
  ]
} 
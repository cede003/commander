{
  "metadata": {
    "name": "Calculator Workflow",
    "description": "Use an online calculator to perform mathematical calculations",
    "author": "Commander",
    "schema_version": "1.0.0"
  },
  "inputs": {
    "calculator_url": "https://www.calculator.net",
    "first_number": "5",
    "second_number": "7"
  },
  "nodes": {
    "start_notification": {
      "id": "start_notification",
      "domain": "browser",
      "operation": "console_log",
      "properties": {
        "message": "Starting calculator workflow",
        "level": "info"
      }
    },
    "navigate_to_calculator": {
      "id": "navigate_to_calculator",
      "domain": "browser",
      "operation": "goto",
      "properties": {
        "url": "$calculator_url"
      },
      "error_handling": {
        "strategy": "retry",
        "max_retry_attempts": 3
      }
    },
    "wait_for_page_load": {
      "id": "wait_for_page_load",
      "domain": "browser",
      "operation": "wait_for_timeout",
      "properties": {
        "timeout": 1000
      }
    },
    "click_first_number": {
      "id": "click_first_number",
      "domain": "browser",
      "operation": "click",
      "properties": {
        "selector": "span[onclick*='$first_number'], span.scinm:has-text('$first_number')"
      }
    },
    "click_operation": {
      "id": "click_operation",
      "domain": "browser",
      "operation": "click",
      "properties": {
        "selector": "span[onclick*='*'], span.scinm:has-text('*'), span[onclick*='multiply']"
      }
    },
    "click_second_number": {
      "id": "click_second_number",
      "domain": "browser",
      "operation": "click",
      "properties": {
        "selector": "span[onclick*='$second_number'], span.scinm:has-text('$second_number')"
      }
    },
    "click_equals": {
      "id": "click_equals",
      "domain": "browser",
      "operation": "click",
      "properties": {
        "selector": "span[onclick*='='], span.scinm:has-text('='), span[onclick*='equals']"
      }
    },
    "wait_for_result": {
      "id": "wait_for_result",
      "domain": "browser",
      "operation": "wait_for_timeout",
      "properties": {
        "timeout": 1000
      }
    },
    "get_calculation_result": {
      "id": "get_calculation_result",
      "domain": "browser",
      "operation": "text_content",
      "properties": {
        "selector": "#sciOutPut"
      },
      "outputs": {
        "calculation_result": "string"
      }
    },
    "get_page_title": {
      "id": "get_page_title",
      "domain": "browser",
      "operation": "title"
    },
    "log_calculation": {
      "id": "log_calculation",
      "domain": "browser",
      "operation": "console_log",
      "properties": {
        "message": "Output exists: $outputs.get_calculation_result, Result field: $outputs.get_calculation_result.calculation_result"
      }
    }
  },
  "edges": [
    {
      "from": "start_notification",
      "to": "navigate_to_calculator"
    },
    {
      "from": "navigate_to_calculator",
      "to": "wait_for_page_load"
    },
    {
      "from": "wait_for_page_load",
      "to": "click_first_number"
    },
    {
      "from": "click_first_number",
      "to": "click_operation"
    },
    {
      "from": "click_operation",
      "to": "click_second_number"
    },
    {
      "from": "click_second_number",
      "to": "click_equals"
    },
    {
      "from": "click_equals",
      "to": "wait_for_result"
    },
    {
      "from": "wait_for_result",
      "to": "get_calculation_result"
    },
    {
      "from": "get_calculation_result",
      "to": "get_page_title"
    },
    {
      "from": "get_page_title",
      "to": "log_calculation"
    }
  ]
}
{
  "metadata": {
    "name": "Test Workflow Execution",
    "description": "Sequential browser steps to validate execution engine",
    "workflow_version": "1.0.0",
    "schema_version": "1.0.0"
  },
  "properties": {
    "skip_conditional": false
  },
  "default_error_handling": {
    "strategy": "continue",
    "max_attempts": 2,
    "retry_delay": 1,
    "pause_seconds": 1
  },
  "nodes": {
    "notify_start": {
      "id": "notify_start",
      "domain": "browser",
      "properties": {
        "message": "Starting test workflow",
        "level": "info"
      },
      "operation": "console_log"
    },
    "go_example": {
      "id": "go_example",
      "domain": "browser",
      "properties": {
        "url": "https://example.com"
      },
      "operation": "goto"
    },
    "wait_short": {
      "id": "wait_short",
      "domain": "browser",
      "properties": {
        "timeout": 500
      },
      "operation": "wait_for_timeout"
    },
    "get_title_example": {
      "id": "get_title_example",
      "domain": "browser",
      "properties": {},
      "operation": "get_title"
    },
    "log_title_if_example": {
      "id": "log_title_if_example",
      "domain": "browser",
      "properties": {
        "message": "Title: {{results.get_title_example.result}}"
      },
      "operation": "console_log"
    },
    "go_wikipedia": {
      "id": "go_wikipedia",
      "domain": "browser",
      "properties": {
        "url": "https://www.wikipedia.org"
      },
      "operation": "goto"
    },
    "wait_short_2": {
      "id": "wait_short_2",
      "domain": "browser",
      "properties": {
        "timeout": 500
      },
      "operation": "wait_for_timeout"
    },
    "get_current_url": {
      "id": "get_current_url",
      "domain": "browser",
      "properties": {},
      "operation": "url"
    },
    "conditional_log": {
      "id": "conditional_log",
      "domain": "browser",
      "conditions": "not inputs.skip_conditional",
      "properties": {
        "message": "URL: {{results.get_current_url.result}}"
      },
      "operation": "console_log"
    },
    "notify_end": {
      "id": "notify_end",
      "domain": "browser",
      "properties": {
        "message": "Finished test workflow",
        "level": "success"
      },
      "operation": "console_log"
    }
  },
  "edges": [
    {
      "from": "notify_start",
      "to": "go_example"
    },
    {
      "from": "go_example",
      "to": "wait_short"
    },
    {
      "from": "wait_short",
      "to": "get_title_example"
    },
    {
      "from": "get_title_example",
      "to": "log_title_if_example",
      "condition": "results.get_title_example.result == 'Example Domain'"
    },
    {
      "from": "log_title_if_example",
      "to": "go_wikipedia"
    },
    {
      "from": "get_title_example",
      "to": "go_wikipedia",
      "condition": "results.get_title_example.result != 'Example Domain'"
    },
    {
      "from": "go_wikipedia",
      "to": "wait_short_2"
    },
    {
      "from": "wait_short_2",
      "to": "get_current_url"
    },
    {
      "from": "get_current_url",
      "to": "conditional_log"
    },
    {
      "from": "conditional_log",
      "to": "notify_end"
    }
  ]
}
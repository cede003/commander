{
  "metadata": {
    "name": "Browser Interaction Workflow",
    "author": "Commander",
    "version": "1.0.0",
    "description": "Example workflow that works with any page in the BrowserView"
  },
  "inputs": {
    "target_url": "https://www.google.com"
  },
  "nodes": {
    "start_notification": {
      "id": "start_notification",
      "domain": "browser",
      "type": "notification",
      "subtype": "console_log",
      "properties": {
        "log_level": "info"
      },
      "inputs": {
        "title": "Workflow Started",
        "message": "Starting browser interaction workflow"
      },
      "outputs": {
        "timestamp": "string"
      }
    },
    "navigate_to_page": {
      "id": "navigate_to_page",
      "domain": "browser",
      "type": "action",
      "subtype": "goto",
      "properties": {
        "timeout": 30000,
        "wait_for_load": true
      },
      "inputs": {
        "url": "{{inputs.target_url}}"
      },
      "outputs": {
        "url": "string",
        "success": "boolean"
      },
      "error_handling": {
        "retry": true,
        "max_attempts": 3
      }
    },
    "click_body": {
      "id": "click_body",
      "domain": "browser",
      "type": "action",
      "subtype": "click",
      "properties": {
        "method": "by_selector",
        "wait_for_element": true,
        "timeout": 10000
      },
      "inputs": {
        "selector": "body",
        "wait_for": true
      },
      "outputs": {
        "selector": "string",
        "success": "boolean"
      },
      "error_handling": {
        "retry": true,
        "max_attempts": 2
      }
    },
    "success_notification": {
      "id": "success_notification",
      "domain": "browser",
      "type": "notification",
      "subtype": "console_log",
      "properties": {
        "log_level": "success"
      },
      "inputs": {
        "title": "Workflow Complete",
        "message": "Successfully navigated and interacted with page"
      },
      "outputs": {
        "timestamp": "string"
      }
    }
  },
  "edges": [
    {
      "from": "start_notification",
      "to": "navigate_to_page"
    },
    {
      "from": "navigate_to_page",
      "to": "click_body"
    },
    {
      "from": "click_body",
      "to": "success_notification"
    }
  ]
} 
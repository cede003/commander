{
  "metadata": {
    "name": "New Action Workflow",
    "author": "Commander",
    "version": "1.0.0",
    "description": "A new workflow demonstrating the current schema"
  },
  "inputs": {
    "search_url": "https://www.google.com",
    "search_term": "playwright automation"
  },
  "nodes": {
    "start_workflow": {
      "id": "start_workflow",
      "domain": "browser",
      "type": "notification",
      "subtype": "console_log",
      "properties": {
        "log_level": "info"
      },
      "inputs": {
        "title": "Workflow Started",
        "message": "Starting new action workflow"
      },
      "outputs": {
        "timestamp": "string"
      }
    },
    "navigate_to_google": {
      "id": "navigate_to_google",
      "domain": "browser",
      "type": "action",
      "subtype": "goto",
      "properties": {
        "timeout": 30000,
        "wait_for_load": true
      },
      "inputs": {
        "url": "{{inputs.search_url}}"
      },
      "outputs": {
        "url": "string",
        "success": "boolean"
      },
      "error_handling": {
        "retry": true,
        "max_attempts": 3
      }
    },
    "click_search_box": {
      "id": "click_search_box",
      "domain": "browser",
      "type": "action",
      "subtype": "click",
      "properties": {
        "method": "by_selector",
        "wait_for_element": true,
        "timeout": 10000
      },
      "inputs": {
        "selector": "textarea[name='q'], input[name='q']",
        "wait_for": true
      },
      "outputs": {
        "selector": "string",
        "success": "boolean"
      },
      "error_handling": {
        "retry": true,
        "max_attempts": 2
      }
    },
    "workflow_complete": {
      "id": "workflow_complete",
      "domain": "browser",
      "type": "notification",
      "subtype": "console_log",
      "properties": {
        "log_level": "success"
      },
      "inputs": {
        "title": "Workflow Complete",
        "message": "Successfully navigated to Google and clicked search box"
      },
      "outputs": {
        "timestamp": "string"
      }
    }
  },
  "edges": [
    {
      "from": "start_workflow",
      "to": "navigate_to_google"
    },
    {
      "from": "navigate_to_google",
      "to": "click_search_box"
    },
    {
      "from": "click_search_box",
      "to": "workflow_complete"
    }
  ]
} 
{
  "metadata": {
    "name": "Comprehensive Testing Workflow",
    "description": "Demonstrates comprehensive testing and validation using all Playwright operations in a real-world testing scenario",
    "author": "Commander",
    "schema_version": "1.0.0"
  },
  "inputs": {
    "test_url": "https://the-internet.herokuapp.com",
    "login_url": "https://the-internet.herokuapp.com/login",
    "dynamic_url": "https://the-internet.herokuapp.com/dynamic_loading/1",
    "checkboxes_url": "https://the-internet.herokuapp.com/checkboxes",
    "dropdown_url": "https://the-internet.herokuapp.com/dropdown"
  },
  "nodes": {
    "start_testing": {
      "id": "start_testing",
      "domain": "browser",
      "operation": "console_log",
      "arguments": {
        "message": "Starting comprehensive testing workflow",
        "level": "info"
      }
    },
    "navigate_to_main": {
      "id": "navigate_to_main",
      "domain": "browser",
      "operation": "goto",
      "arguments": {
        "url": "$test_url"
      }
    },
    "wait_for_main_load": {
      "id": "wait_for_main_load",
      "domain": "browser",
      "operation": "wait_for_load_state",
      "arguments": {
        "state": "domcontentloaded"
      }
    },
    "get_main_title": {
      "id": "get_main_title",
      "domain": "browser",
      "operation": "title"
    },
    "get_main_url": {
      "id": "get_main_url",
      "domain": "browser",
      "operation": "url"
    },
    "wait_for_main_content": {
      "id": "wait_for_main_content",
      "domain": "browser",
      "operation": "wait_for_selector",
      "arguments": {
        "selector": "h1"
      }
    },
    "check_main_heading_visible": {
      "id": "check_main_heading_visible",
      "domain": "browser",
      "operation": "is_visible",
      "arguments": {
        "selector": "h1"
      }
    },
    "get_main_heading_text": {
      "id": "get_main_heading_text",
      "domain": "browser",
      "operation": "text_content",
      "arguments": {
        "selector": "h1"
      }
    },
    "navigate_to_login": {
      "id": "navigate_to_login",
      "domain": "browser",
      "operation": "goto",
      "arguments": {
        "url": "$login_url"
      }
    },
    "wait_for_login_load": {
      "id": "wait_for_login_load",
      "domain": "browser",
      "operation": "wait_for_load_state",
      "arguments": {
        "state": "networkidle"
      }
    },
    "wait_for_login_form": {
      "id": "wait_for_login_form",
      "domain": "browser",
      "operation": "wait_for_selector",
      "arguments": {
        "selector": "#username"
      }
    },
    "check_username_field_enabled": {
      "id": "check_username_field_enabled",
      "domain": "browser",
      "operation": "is_enabled",
      "arguments": {
        "selector": "#username"
      }
    },
    "fill_username_field": {
      "id": "fill_username_field",
      "domain": "browser",
      "operation": "fill",
      "arguments": {
        "selector": "#username",
        "value": "tomsmith"
      }
    },
    "type_additional_username": {
      "id": "type_additional_username",
      "domain": "browser",
      "operation": "type",
      "arguments": {
        "selector": "#username",
        "text": " (test user)"
      }
    },
    "clear_username_field": {
      "id": "clear_username_field",
      "domain": "browser",
      "operation": "fill",
      "arguments": {
        "selector": "#username",
        "value": ""
      }
    },
    "fill_username_again": {
      "id": "fill_username_again",
      "domain": "browser",
      "operation": "fill",
      "arguments": {
        "selector": "#username",
        "value": "tomsmith"
      }
    },
    "check_password_field": {
      "id": "check_password_field",
      "domain": "browser",
      "operation": "is_visible",
      "arguments": {
        "selector": "#password"
      }
    },
    "fill_password_field": {
      "id": "fill_password_field",
      "domain": "browser",
      "operation": "fill",
      "arguments": {
        "selector": "#password",
        "value": "SuperSecretPassword!"
      }
    },
    "focus_login_button": {
      "id": "focus_login_button",
      "domain": "browser",
      "operation": "focus",
      "arguments": {
        "selector": "button[type='submit']"
      }
    },
    "hover_over_login_button": {
      "id": "hover_over_login_button",
      "domain": "browser",
      "operation": "hover",
      "arguments": {
        "selector": "button[type='submit']"
      }
    },
    "click_login_button": {
      "id": "click_login_button",
      "domain": "browser",
      "operation": "click",
      "arguments": {
        "selector": "button[type='submit']"
      }
    },
    "wait_for_login_result": {
      "id": "wait_for_login_result",
      "domain": "browser",
      "operation": "wait_for_timeout",
      "arguments": {
        "timeout": 2000
      }
    },
    "check_login_success": {
      "id": "check_login_success",
      "domain": "browser",
      "operation": "is_visible",
      "arguments": {
        "selector": ".flash.success"
      }
    },
    "get_success_message": {
      "id": "get_success_message",
      "domain": "browser",
      "operation": "text_content",
      "arguments": {
        "selector": ".flash.success"
      }
    },
    "take_login_screenshot": {
      "id": "take_login_screenshot",
      "domain": "browser",
      "operation": "screenshot",
      "arguments": {
        "path": "logs/login_success_screenshot.png"
      }
    },
    "navigate_to_checkboxes": {
      "id": "navigate_to_checkboxes",
      "domain": "browser",
      "operation": "goto",
      "arguments": {
        "url": "$checkboxes_url"
      }
    },
    "wait_for_checkboxes_load": {
      "id": "wait_for_checkboxes_load",
      "domain": "browser",
      "operation": "wait_for_load_state",
      "arguments": {
        "state": "domcontentloaded"
      }
    },
    "wait_for_checkboxes": {
      "id": "wait_for_checkboxes",
      "domain": "browser",
      "operation": "wait_for_selector",
      "arguments": {
        "selector": "input[type='checkbox']"
      }
    },
    "get_all_checkboxes": {
      "id": "get_all_checkboxes",
      "domain": "browser",
      "operation": "query_selector_all",
      "arguments": {
        "selector": "input[type='checkbox']"
      }
    },
    "check_first_checkbox_state": {
      "id": "check_first_checkbox_state",
      "domain": "browser",
      "operation": "is_checked",
      "arguments": {
        "selector": "input[type='checkbox']:first-of-type"
      }
    },
    "check_first_checkbox": {
      "id": "check_first_checkbox",
      "domain": "browser",
      "operation": "check",
      "arguments": {
        "selector": "input[type='checkbox']:first-of-type"
      }
    },
    "verify_first_checkbox_checked": {
      "id": "verify_first_checkbox_checked",
      "domain": "browser",
      "operation": "is_checked",
      "arguments": {
        "selector": "input[type='checkbox']:first-of-type"
      }
    },
    "uncheck_first_checkbox": {
      "id": "uncheck_first_checkbox",
      "domain": "browser",
      "operation": "uncheck",
      "arguments": {
        "selector": "input[type='checkbox']:first-of-type"
      }
    },
    "navigate_to_dropdown": {
      "id": "navigate_to_dropdown",
      "domain": "browser",
      "operation": "goto",
      "arguments": {
        "url": "$dropdown_url"
      }
    },
    "wait_for_dropdown_load": {
      "id": "wait_for_dropdown_load",
      "domain": "browser",
      "operation": "wait_for_load_state",
      "arguments": {
        "state": "domcontentloaded"
      }
    },
    "wait_for_dropdown_element": {
      "id": "wait_for_dropdown_element",
      "domain": "browser",
      "operation": "wait_for_selector",
      "arguments": {
        "selector": "#dropdown"
      }
    },
    "check_dropdown_visible": {
      "id": "check_dropdown_visible",
      "domain": "browser",
      "operation": "is_visible",
      "arguments": {
        "selector": "#dropdown"
      }
    },
    "select_dropdown_option": {
      "id": "select_dropdown_option",
      "domain": "browser",
      "operation": "select_option",
      "arguments": {
        "selector": "#dropdown",
        "value": "1"
      }
    },
    "navigate_to_dynamic": {
      "id": "navigate_to_dynamic",
      "domain": "browser",
      "operation": "goto",
      "arguments": {
        "url": "$dynamic_url"
      }
    },
    "wait_for_dynamic_load": {
      "id": "wait_for_dynamic_load",
      "domain": "browser",
      "operation": "wait_for_load_state",
      "arguments": {
        "state": "domcontentloaded"
      }
    },
    "wait_for_start_button": {
      "id": "wait_for_start_button",
      "domain": "browser",
      "operation": "wait_for_selector",
      "arguments": {
        "selector": "#start button"
      }
    },
    "click_start_button": {
      "id": "click_start_button",
      "domain": "browser",
      "operation": "click",
      "arguments": {
        "selector": "#start button"
      }
    },
    "wait_for_loading_function": {
      "id": "wait_for_loading_function",
      "domain": "browser",
      "operation": "wait_for_function",
      "arguments": {
        "function": "() => document.querySelector('#finish h4') !== null"
      }
    },
    "get_finished_text": {
      "id": "get_finished_text",
      "domain": "browser",
      "operation": "text_content",
      "arguments": {
        "selector": "#finish h4"
      }
    },
    "go_back_to_main": {
      "id": "go_back_to_main",
      "domain": "browser",
      "operation": "go_back"
    },
    "reload_main_page": {
      "id": "reload_main_page",
      "domain": "browser",
      "operation": "reload"
    },
    "wait_for_reload": {
      "id": "wait_for_reload",
      "domain": "browser",
      "operation": "wait_for_timeout",
      "arguments": {
        "timeout": 1000
      }
    },
    "wait_for_main_url": {
      "id": "wait_for_main_url",
      "domain": "browser",
      "operation": "wait_for_url",
      "arguments": {
        "url": "**herokuapp.com**"
      }
    },
    "get_final_page_content": {
      "id": "get_final_page_content",
      "domain": "browser",
      "operation": "content"
    },
    "get_final_page_title": {
      "id": "get_final_page_title",
      "domain": "browser",
      "operation": "title"
    },
    "take_final_screenshot": {
      "id": "take_final_screenshot",
      "domain": "browser",
      "operation": "screenshot",
      "arguments": {
        "path": "logs/comprehensive_testing_screenshot.png"
      }
    },
    "end_testing": {
      "id": "end_testing",
      "domain": "browser",
      "operation": "console_log",
      "arguments": {
        "message": "Comprehensive testing workflow completed successfully",
        "level": "info"
      }
    }
  },
  "edges": [
    {
      "from": "start_testing",
      "to": "navigate_to_main"
    },
    {
      "from": "navigate_to_main",
      "to": "wait_for_main_load"
    },
    {
      "from": "wait_for_main_load",
      "to": "get_main_title"
    },
    {
      "from": "get_main_title",
      "to": "get_main_url"
    },
    {
      "from": "get_main_url",
      "to": "wait_for_main_content"
    },
    {
      "from": "wait_for_main_content",
      "to": "check_main_heading_visible"
    },
    {
      "from": "check_main_heading_visible",
      "to": "get_main_heading_text"
    },
    {
      "from": "get_main_heading_text",
      "to": "navigate_to_login"
    },
    {
      "from": "navigate_to_login",
      "to": "wait_for_login_load"
    },
    {
      "from": "wait_for_login_load",
      "to": "wait_for_login_form"
    },
    {
      "from": "wait_for_login_form",
      "to": "check_username_field_enabled"
    },
    {
      "from": "check_username_field_enabled",
      "to": "fill_username_field"
    },
    {
      "from": "fill_username_field",
      "to": "type_additional_username"
    },
    {
      "from": "type_additional_username",
      "to": "clear_username_field"
    },
    {
      "from": "clear_username_field",
      "to": "fill_username_again"
    },
    {
      "from": "fill_username_again",
      "to": "check_password_field"
    },
    {
      "from": "check_password_field",
      "to": "fill_password_field"
    },
    {
      "from": "fill_password_field",
      "to": "focus_login_button"
    },
    {
      "from": "focus_login_button",
      "to": "hover_over_login_button"
    },
    {
      "from": "hover_over_login_button",
      "to": "click_login_button"
    },
    {
      "from": "click_login_button",
      "to": "wait_for_login_result"
    },
    {
      "from": "wait_for_login_result",
      "to": "check_login_success"
    },
    {
      "from": "check_login_success",
      "to": "get_success_message"
    },
    {
      "from": "get_success_message",
      "to": "take_login_screenshot"
    },
    {
      "from": "take_login_screenshot",
      "to": "navigate_to_checkboxes"
    },
    {
      "from": "navigate_to_checkboxes",
      "to": "wait_for_checkboxes_load"
    },
    {
      "from": "wait_for_checkboxes_load",
      "to": "wait_for_checkboxes"
    },
    {
      "from": "wait_for_checkboxes",
      "to": "get_all_checkboxes"
    },
    {
      "from": "get_all_checkboxes",
      "to": "check_first_checkbox_state"
    },
    {
      "from": "check_first_checkbox_state",
      "to": "check_first_checkbox"
    },
    {
      "from": "check_first_checkbox",
      "to": "verify_first_checkbox_checked"
    },
    {
      "from": "verify_first_checkbox_checked",
      "to": "uncheck_first_checkbox"
    },
    {
      "from": "uncheck_first_checkbox",
      "to": "navigate_to_dropdown"
    },
    {
      "from": "navigate_to_dropdown",
      "to": "wait_for_dropdown_load"
    },
    {
      "from": "wait_for_dropdown_load",
      "to": "wait_for_dropdown_element"
    },
    {
      "from": "wait_for_dropdown_element",
      "to": "check_dropdown_visible"
    },
    {
      "from": "check_dropdown_visible",
      "to": "select_dropdown_option"
    },
    {
      "from": "select_dropdown_option",
      "to": "navigate_to_dynamic"
    },
    {
      "from": "navigate_to_dynamic",
      "to": "wait_for_dynamic_load"
    },
    {
      "from": "wait_for_dynamic_load",
      "to": "wait_for_start_button"
    },
    {
      "from": "wait_for_start_button",
      "to": "click_start_button"
    },
    {
      "from": "click_start_button",
      "to": "wait_for_loading_function"
    },
    {
      "from": "wait_for_loading_function",
      "to": "get_finished_text"
    },
    {
      "from": "get_finished_text",
      "to": "go_back_to_main"
    },
    {
      "from": "go_back_to_main",
      "to": "reload_main_page"
    },
    {
      "from": "reload_main_page",
      "to": "wait_for_reload"
    },
    {
      "from": "wait_for_reload",
      "to": "wait_for_main_url"
    },
    {
      "from": "wait_for_main_url",
      "to": "get_final_page_content"
    },
    {
      "from": "get_final_page_content",
      "to": "get_final_page_title"
    },
    {
      "from": "get_final_page_title",
      "to": "take_final_screenshot"
    },
    {
      "from": "take_final_screenshot",
      "to": "end_testing"
    }
  ]
} 
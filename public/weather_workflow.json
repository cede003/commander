{
  "metadata": {
    "name": "Weather Check Workflow",
    "description": "Navigate to weather.com and get current weather information",
    "author": "Commander",
    "version": "1.0.0"
  },
  "inputs": {
    "weather_url": "https://weather.com",
    "city": "New York"
  },
  "nodes": {
    "start_notification": {
      "id": "start_notification",
      "domain": "browser",
      "type": "notification",
      "subtype": "console_log",
      "inputs": {
        "message": "Starting weather check workflow",
        "level": "info"
      }
    },
    "navigate_to_weather": {
      "id": "navigate_to_weather",
      "domain": "browser",
      "type": "action",
      "subtype": "goto",
      "inputs": {
        "url": "{{inputs.weather_url}}"
      },
      "error_handling": {
        "retry": true,
        "max_attempts": 3
      }
    },
    "wait_for_page_load": {
      "id": "wait_for_page_load",
      "domain": "browser",
      "type": "event",
      "subtype": "wait_for_timeout",
      "inputs": {
        "timeout": 3000
      }
    },
    "search_city": {
      "id": "search_city",
      "domain": "browser",
      "type": "action",
      "subtype": "fill",
      "inputs": {
        "selector": "input[placeholder*='search'], input[name*='search'], input[type='search']",
        "value": "{{inputs.city}}"
      }
    },
    "submit_search": {
      "id": "submit_search",
      "domain": "browser",
      "type": "action",
      "subtype": "press",
      "inputs": {
        "key": "Enter"
      }
    },
    "wait_for_results": {
      "id": "wait_for_results",
      "domain": "browser",
      "type": "event",
      "subtype": "wait_for_load_state",
      "inputs": {
        "state": "networkidle"
      }
    },
    "get_temperature": {
      "id": "get_temperature",
      "domain": "browser",
      "type": "observation",
      "subtype": "text_content",
      "inputs": {
        "selector": "[data-testid*='temperature'], .temperature, .temp, [class*='temp']"
      }
    },
    "get_weather_description": {
      "id": "get_weather_description",
      "domain": "browser",
      "type": "observation",
      "subtype": "text_content",
      "inputs": {
        "selector": "[data-testid*='description'], .description, .weather-desc, [class*='desc']"
      }
    },
    "get_page_title": {
      "id": "get_page_title",
      "domain": "browser",
      "type": "observation",
      "subtype": "get_title",
      "inputs": {}
    },
    "log_weather_info": {
      "id": "log_weather_info",
      "domain": "browser",
      "type": "notification",
      "subtype": "console_log",
      "inputs": {
        "message": "Weather information retrieved successfully",
        "level": "success"
      }
    }
  },
  "edges": [
    {
      "from": "start_notification",
      "to": "navigate_to_weather"
    },
    {
      "from": "navigate_to_weather",
      "to": "wait_for_page_load"
    },
    {
      "from": "wait_for_page_load",
      "to": "search_city"
    },
    {
      "from": "search_city",
      "to": "submit_search"
    },
    {
      "from": "submit_search",
      "to": "wait_for_results"
    },
    {
      "from": "wait_for_results",
      "to": "get_temperature"
    },
    {
      "from": "get_temperature",
      "to": "get_weather_description"
    },
    {
      "from": "get_weather_description",
      "to": "get_page_title"
    },
    {
      "from": "get_page_title",
      "to": "log_weather_info"
    }
  ]
} 